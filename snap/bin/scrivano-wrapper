#!/bin/bash
# Scrivano wrapper script for Snap package

set -e

export LD_LIBRARY_PATH="$SNAP/lib:$SNAP/lib/x86_64-linux-gnu:$SNAP/lib/x86_64-linux-gnu/pulseaudio:$LD_LIBRARY_PATH"
export XKB_CONFIG_ROOT="$SNAP/xkb"
export LIBGL_DRIVERS_PATH="$SNAP/lib/x86_64-linux-gnu/dri"
export DRI_DRIVER_DIR="$SNAP/lib/x86_64-linux-gnu/dri"
export LIBGL_ALWAYS_SOFTWARE="1"
export MESA_LOADER_DRIVER_OVERRIDE="swrast"
export GTK_THEME="Adwaita"

MODELS_DIR="${SNAP_USER_DATA:-$HOME/.local/share/scrivano}/models"
BUNDLED_MODELS_DIR="$SNAP/models"

mkdir -p "$MODELS_DIR"

ensure_model() {
    local model_name="$1"
    local bundled_path="$BUNDLED_MODELS_DIR/$model_name"
    local user_path="$MODELS_DIR/$model_name"

    if [ -f "$user_path" ]; then
        echo "Model already present: $model_name"
        return 0
    fi

    if [ -f "$bundled_path" ]; then
        echo "Copying bundled model: $model_name"
        cp "$bundled_path" "$user_path"
        echo "Model ready: $model_name"
        return 0
    fi

    echo "Missing bundled model: $model_name"
    echo "Expected at: $bundled_path"
    return 1
}

ensure_model "ggml-tiny.bin" || true
ensure_model "ggml-small-q5_1.bin" || true

if [ "${SCRIVANO_SELFTEST:-0}" = "1" ]; then
    echo "Wrapper selftest complete"
    exit 0
fi

echo ""
echo "Launching Scrivano..."
exec "$SNAP/scrivano" "$@"
